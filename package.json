{
    "name": "@ipregistry/next",
    "description": "Official Ipregistry integration for Next.js: middleware-driven IP geolocation and threat detection for every request.",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./middleware": {
            "import": {
                "types": "./dist/middleware.d.ts",
                "default": "./dist/middleware.js"
            },
            "require": {
                "types": "./dist/middleware.d.cts",
                "default": "./dist/middleware.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "homepage": "https://ipregistry.co",
    "license": "Apache-2.0",
    "keywords": [
        "nextjs",
        "next",
        "middleware",
        "edge",
        "geolocation",
        "ip",
        "ipaddress",
        "ip intelligence",
        "ip geolocation",
        "ipregistry",
        "geoblocking",
        "gdpr",
        "threat-data",
        "typescript",
        "vercel"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ipregistry/ipregistry-next.git"
    },
    "bugs": {
        "url": "https://github.com/ipregistry/ipregistry-next/issues"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist/",
        "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|tsx|json|md)\"",
        "prepack": "npm run clean && npm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "author": "Ipregistry <support@ipregistry.co>",
    "dependencies": {
        "@ipregistry/client": "^7.0.0"
    },
    "peerDependencies": {
        "next": ">=14.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "next": "^15.0.0",
        "prettier": "^3.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "files": [
        "dist/**"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "private": false
}
